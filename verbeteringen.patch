@@ -28,9 +43,67 @@ export class Level extends Scene {
 
         // HIER ZETTEN WE DE CAMERA VAST:
         this.camera.strategy.lockToActor(this.myplayer);
-        
-        
+
         // De camera mag niet buiten deze box kijken (0 t/m 1920 breed, 0 t/m 1080 hoog)
